# Each integration is gated independently: leave a value unset to keep that one
# feature on the local SQLite/NumPy path, or name a table/bucket to move just
# that feature onto AWS. Nothing here is a secret — credentials come from the
# standard boto3 provider chain (AWS_PROFILE below, or an IAM role on Lambda).
AWS_REGION=us-west-2
# Local only. Omit on Lambda so the function's execution role is used instead.
AWS_PROFILE=csub-policy

# Retrieval + generation.
BEDROCK_KB_ID=
# Leave both unset for unguardrailed generation; values come from the CDK stack outputs.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=
CORPUS_BUCKET=

# DynamoDB tables. The DYNAMODB_* spellings from Yaza_DynamoDB_Work_Summary.md §7
# are accepted as aliases for five of these, so either runbook works:
#   DYNAMODB_CONFLICTS_TABLE        -> DDB_CONFLICTS_TABLE
#   DYNAMODB_SOURCE_REGISTRY_TABLE  -> DDB_REGISTRY_TABLE
#   DYNAMODB_ACCESS_CONTROL_TABLE   -> DDB_PERMISSIONS_TABLE
#   DYNAMODB_DRAFT_VERSIONS_TABLE   -> DDB_DRAFTS_TABLE
#   DYNAMODB_FEEDBACK_TABLE         -> DDB_FEEDBACK_TABLE
DDB_CONFLICTS_TABLE=
DDB_UPLOADS_TABLE=
DDB_REGISTRY_TABLE=
DDB_PERMISSIONS_TABLE=
DDB_DRAFTS_TABLE=
DDB_FEEDBACK_TABLE=
DDB_RECURRING_QUESTIONS_TABLE=

# Point at DynamoDB Local for offline testing; leave blank for real AWS.
DYNAMODB_ENDPOINT_URL=

# Sign-in stays local for the demo (hardcoded accounts in backend/app/auth.py).
# Set both to switch the API onto verified Cognito claims.
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
