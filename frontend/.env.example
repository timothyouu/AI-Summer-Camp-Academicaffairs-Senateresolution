# Backend base URL. For the local demo, point this at the running FastAPI server
# so the UI calls the real backend (answers + citations + conflicts) instead of the
# static mock facade: VITE_API_BASE_URL=http://127.0.0.1:8000
# In AWS, set it to the API Gateway invoke URL. Leave unset only to demo the mock UI.
VITE_API_BASE_URL=

# Optional Lambda Function URL (AgentFunctionUrl stack output) for the two
# long-running agent endpoints (chat, check-resolution). API Gateway HTTP API
# caps integrations at ~29s; the Function URL allows up to 15 min. Unset ⇒ these
# fall back to VITE_API_BASE_URL (fine locally).
VITE_AGENT_BASE_URL=

# Optional Cognito Hosted UI sign-in. All four values are required to enable SSO.
VITE_USE_COGNITO=false
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-west-2.amazoncognito.com
VITE_COGNITO_CLIENT_ID=
# Register this exact callback URL in the Cognito app client's allowed callback URLs.
VITE_REDIRECT_URI=http://localhost:5173/auth/callback
